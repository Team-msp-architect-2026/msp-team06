# 사용법: 이 파일을 secrets.auto.tfvars 로 복사 후 실제 값 입력
#   cp secrets.auto.tfvars.example secrets.auto.tfvars
#
# secrets.auto.tfvars 는 .gitignore 처리되어 있어 커밋되지 않습니다.
# 각자 로컬에만 보관하세요.

kakao_rest_api_key  = "여기에_카카오_REST_API_키_입력"
kakao_js_api_key    = "여기에_카카오_JavaScript_API_키_입력"
naver_client_id     = "여기에_네이버_Client_ID_입력"
naver_client_secret = "여기에_네이버_Client_Secret_입력"
molit_service_key   = "여기에_국토부_공공데이터_서비스키_입력"   # 실거래가 API (엔드포인트 4개)
mois_service_key    = "여기에_행안부_공공데이터_서비스키_입력"   # 도로명주소 API

# ArgoCD — GitHub repo가 private인 경우에만 입력 (public이면 빈 문자열 유지)
# GitHub → Settings → Developer settings → Personal access tokens → Fine-grained tokens
# 권한: Contents (read-only)
github_token        = ""

# redis_auth_token은 tfvars에 기입 금지 — apply 시 환경변수로 주입:
#   export TF_VAR_redis_auth_token="your-strong-token"
#   terraform apply -target=module.elasticache
