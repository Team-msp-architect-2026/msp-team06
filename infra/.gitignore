# -----------------------------------------------------------------------
# Claude Code 로컬 설정 (AI 메모리 — 커밋 금지)
# -----------------------------------------------------------------------
.claude/

# -----------------------------------------------------------------------
# Terraform
# -----------------------------------------------------------------------

# 프로바이더 플러그인 / 초기화 디렉터리
**/.terraform/
**/.terraform.lock.hcl

# 상태 파일 (원격 S3 백엔드 사용 — 로컬에 생성되면 안 됨)
*.tfstate
*.tfstate.*
*.tfstate.backup

# 플랜 파일
*.tfplan

# 크래시 로그
crash.log
crash.*.log

# tfvars — 민감 정보 포함 가능
# 주의: 이 프로젝트의 terraform.tfvars는 인프라 크기 설정만 포함하므로
#        커밋해도 무방하나, 실수로 시크릿을 넣을 경우를 대비해 *.auto.tfvars만 제외
*.auto.tfvars
*.auto.tfvars.json
secrets.tfvars

# 예시 파일은 커밋 포함
!*.tfvars.example

# override 파일 (로컬 임시 오버라이드)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI 설정
.terraformrc
terraform.rc

# -----------------------------------------------------------------------
# OS / IDE
# -----------------------------------------------------------------------
.DS_Store
Thumbs.db

# WSL2 — Windows에서 다운로드한 파일에 붙는 Zone.Identifier 메타데이터
*:Zone.Identifier

.vscode/
.idea/
*.swp
*.swo

# -----------------------------------------------------------------------
# Python (백엔드 예정)
# -----------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
.env
.env.*
!.env.example

# -----------------------------------------------------------------------
# Node.js (프론트엔드 예정)
# -----------------------------------------------------------------------
node_modules/
.expo/
dist/
build/
