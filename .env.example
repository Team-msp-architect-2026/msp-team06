# 환경변수 샘플 파일
# 실제 값은 .env에 넣고 이 파일은 깃허브에 올림
# 팀원이 이 파일 보고 .env 파일 직접 만들어서 값 채워넣음

# 앱 설정
APP_ENV=development
APP_PORT=8000
SECRET_KEY=

# DB
DB_HOST=localhost
DB_PORT=5432
DB_NAME=homelens_dev
DB_USER=homelens
DB_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# 외부 API 키
KAKAO_API_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
MOLIT_API_KEY=
ANTHROPIC_API_KEY=